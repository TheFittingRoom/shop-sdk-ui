{
  "name": "@thefittingroom/shop-ui",
  "version": "5.0.34",
  "description": "the fitting room UI library",
  "type": "module",
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheFittingRoom/shop-sdk-ui.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist build",
    "build": "npm run clean && vite build --mode production",
    "watch": "vite build --mode production --watch",
    "serve": "serve . -p 5173 --cors",
    "watch-serve": "trap 'kill 0' EXIT; npm run watch & npm run serve & wait",
    "check": "tsc --noEmit && npm run lint && npm run format:check",
    "gen-types": "sh scripts/gen-types.sh",
    "promote-latest": "sh scripts/promote-latest.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src tests playwright.config.ts",
    "format:check": "prettier --check src tests playwright.config.ts",
    "test": "npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:debug": "PWDEBUG=1 playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-modal": "^3.16.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.6.0",
    "prettier": "^3.6.2",
    "serve": "^14.2.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.3.0",
    "vite-plugin-svgr": "^4.5.0"
  },
  "dependencies": {
    "@emotion/babel-plugin": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "bowser": "^2.13.1",
    "dayjs": "^1.11.19",
    "firebase": "^12.5.0",
    "i18next": "^25.7.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.0",
    "react-modal": "^3.16.3",
    "zustand": "^5.0.9"
  }
}
